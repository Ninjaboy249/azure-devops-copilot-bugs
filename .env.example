# Azure DevOps Configuration
# Copy this file to .env and fill in your values

# Organization URL (e.g., https://dev.azure.com/yourorg)
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/your-organization

# Personal Access Token (PAT) with Work Items Read scope
AZURE_DEVOPS_PAT=your-pat-token-here

# Project Name
AZURE_DEVOPS_PROJECT=your-project-name

# Optional: Default user email for "my bugs" queries
AZURE_DEVOPS_USER_EMAIL=your-email@company.com

# Optional: Team name for sprint queries
AZURE_DEVOPS_TEAM=your-team-name

# Optional: Output directory for reports
OUTPUT_DIR=./output

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
